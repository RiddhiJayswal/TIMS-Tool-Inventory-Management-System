POSTGRES_USER=tims_user
POSTGRES_PASSWORD=tims_pass
POSTGRES_DB=tims_db
DATABASE_URL=postgresql://tims_user:tims_pass@db:5432/tims_db
SECRET_KEY=CHANGE_THIS_generate_a_64_char_hex_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
FRONTEND_BASE_URL=http://localhost:3000

# Gmail / Google Workspace SMTP.
# Use a Google App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-character-google-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true

# SMS provider. Twilio is supported directly.
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

# Generic SMS provider fallback.
# The generic adapter sends JSON: {"to": "...", "message": "...", "from": "..."}
SMS_API_URL=https://your-sms-provider.example/send
SMS_API_KEY=your-sms-provider-api-key
SMS_FROM=TIMS
