# Copy this to .env and fill in every value before running docker compose
# NEVER commit .env to git

POSTGRES_USER=tims_user
POSTGRES_PASSWORD=CHANGE_THIS_strong_password_here
POSTGRES_DB=tims_db
DATABASE_URL=postgresql://tims_user:CHANGE_THIS_strong_password_here@db:5432/tims_db

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_generate_a_64_char_hex_secret

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Your domain (used in password-reset email links)
FRONTEND_BASE_URL=https://tims.riddhijayswal.com

# SMTP (required for password reset emails in production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true

# SMS OTP delivery (required for Request Access mobile OTPs)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

# Optional generic SMS provider fallback. The generic adapter posts JSON with
# to, message, and optional from fields.
SMS_API_URL=
SMS_API_KEY=
SMS_FROM=
